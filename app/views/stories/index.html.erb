<% content_for :title, "Stories" %>
<%= paginate @stories, class: "page-link"  %>
<%= link_to "New story", new_story_path %>
<h4>Stories <%= "- Showing #{ pluralize(@stories.size, 'story') }" %></h4>
<%= link_to "Export", stories_path(format: "csv"), class: "btn btn-outline-primary" %>
<div id="stories">
  <table class="table table-striped table-hover table-sm small">
    <thead>
      <tr>
        <th scope="col"><%= sortable_header("Name", :name) %></th>
        <th scope="col"><%= sortable_header("Likes", :likes_count) %></th>
        <th scope="col"><%= sortable_header("ID", :id) %></th>
      </tr>
      <tr>
        <th scope="col"><%= sortable_header("Description", :description) %></th>
      </tr>
    </thead>
    <tbody>
      <% @stories.each do |story|%>
        <tr>
          <td><%= link_to story.name, story %></td>
          <td><%= story.likes_count %></td>
          <td><%= story.id %></td>
        </tr>
        <tr>
          <td colspan="3">
            <%= story.description %>
            <% unless story.tag_list.empty? %>
                Tags:
                <span class="tags">
                <%= render partial: "tags/tag", collection: story.tags %>
                </span>
                <% end %>
            </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
