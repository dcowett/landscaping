<% content_for :title, "Pins" %>
<%= paginate @pins, params: { filter: params[:filter] } %>
<% current = @current_filter %>

<div class="mb-3">
  <%= filter_button("All Pins", nil, current) %>
  <%= filter_button("With Property", "with_property", current) %>
  <%= filter_button("No Property", "no_property", current) %>
</div>

<h1>Pins</h1>
<%= link_to "New pin", new_pin_path %>

    <% if @pins.any? %>
        <div class="masonry">
          <% @pins.each do |pin| %>
            <div class="masonry-item masonry-content center"></br>
              <%= image_tag(
                (pin.image.attached? ? pin.image.variant(resize_to_limit: [200,200]) : "default_image.png"),
                loading: "lazy",
                class: "img-fluid rounded"
                ) %>
              <br>
              <%= link_to "Show this pin", pin %>
              <% if pin.property %>
                <span class="badge bg-success">
                  <%= link_to pin.property.situs_address, property_path(pin.property), class: "text-white text-decoration-none" %>
                </span>
                <% else %>
                <span class="badge bg-secondary">Standalone</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
          <p class="text-muted">No pins found for this filter.</p>
      <% end %>
<%= paginate @pins, params: { filter: params[:filter] } %>
